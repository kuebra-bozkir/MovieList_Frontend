<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MovieListApp.ViewModels"
             x:Class="MovieListApp.Views.MovieDetailPage"
             x:DataType="vm:MovieDetailViewModel"
             Title="{Binding Movie.Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               Margin="0,60,0,0" />

            <VerticalStackLayout IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                 Spacing="0">

                <!-- Full-width poster -->
                <Image Source="{Binding Detail.PosterOrPlaceholder}"
                       HeightRequest="380"
                       HorizontalOptions="Fill"
                       Aspect="AspectFill" />

                <VerticalStackLayout Padding="20,20,20,40" Spacing="16">

                    <!-- Title + meta -->
                    <Label Text="{Binding Detail.Title}"
                           FontSize="24"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           LineBreakMode="WordWrap" />

                    <HorizontalStackLayout Spacing="8">
                        <Border BackgroundColor="{StaticResource AppSurfaceHigh}"
                                StrokeShape="RoundRectangle 4"
                                StrokeThickness="0"
                                Padding="8,4">
                            <Label Text="{Binding Detail.Year}"
                                   FontSize="12"
                                   TextColor="{StaticResource AppTextSecondary}" />
                        </Border>
                        <Border BackgroundColor="{StaticResource AppSurfaceHigh}"
                                StrokeShape="RoundRectangle 4"
                                StrokeThickness="0"
                                Padding="8,4">
                            <Label Text="{Binding Detail.Runtime}"
                                   FontSize="12"
                                   TextColor="{StaticResource AppTextSecondary}" />
                        </Border>
                        <Border BackgroundColor="{StaticResource AppSurfaceHigh}"
                                StrokeShape="RoundRectangle 4"
                                StrokeThickness="0"
                                Padding="8,4">
                            <Label Text="{Binding Detail.Rated}"
                                   FontSize="12"
                                   TextColor="{StaticResource AppTextSecondary}" />
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" />

                    <!-- Genre -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="GENRE"
                               Style="{StaticResource SectionLabel}" />
                        <Label Text="{Binding Detail.Genre}"
                               FontSize="15" />
                    </VerticalStackLayout>

                    <!-- Director -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="DIRECTOR"
                               Style="{StaticResource SectionLabel}" />
                        <Label Text="{Binding Detail.Director}"
                               FontSize="15" />
                    </VerticalStackLayout>

                    <!-- Cast -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="CAST"
                               Style="{StaticResource SectionLabel}" />
                        <Label Text="{Binding Detail.Actors}"
                               FontSize="15" />
                    </VerticalStackLayout>

                    <!-- Plot -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="PLOT"
                               Style="{StaticResource SectionLabel}" />
                        <Label Text="{Binding Detail.Plot}"
                               FontSize="15"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <!-- Add to List -->
                    <Button Text="Add to a List"
                            Command="{Binding AddToListCommand}"
                            Margin="0,8,0,0"
                            HorizontalOptions="Fill" />

                </VerticalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
